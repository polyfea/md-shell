{
  "name": "@polyfea/md-shell",
  "version": "0.0.1",
  "description": "Polyfea Material Shell Web Component",
  "license": "Apache-2.0",
  "homepage": "https://polyfea.github.io/md-shell/",
  "author": "Polyfea contributors",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/polyfea/md-shell.git"
  },
  "files": [
    "dist/",
    "xliff/",
    "custom-elements.json"
  ],
  "types": "dist/index.d.ts",
  "module": "dist/index.js",
  "keywords": [
    "polyfea",
    "webcomponents",
    "custom-elements",
    "microfrontend",
    "material-design",
    "app-shell"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "prebuild:storybook": "npm run cem",
    "build:storybook": "storybook build",
    "build:docker": "docker build -t polyfea/md-shell -f build/docker/Dockerfile .",
    "cem": "cem analyze",
    "cem-doc": "node ./.scripts/cem-md.js",
    "localize:extract": "lit-localize extract",
    "localize:build": "lit-localize build",
    "localize": "npm run localize:extract && npm run localize:build",
    "precompress": "precompress -t gz,br -e **.gz,**.br,**.map,**.woff2 dist",
    "coverage:browser": "vitest --coverage --browser.headless=false",
    "coverage": "vitest run --coverage --browser.headless",
    "coverage.ci": "xvfb-run npx vitest run --coverage --browser.headless",
    "precoverage.ci": "playwright install --with-deps"
  },
  "dependencies": {
    "@fontsource-variable/material-symbols-outlined": "^5.2.30",
    "@fontsource-variable/roboto-flex": "^5.2.8",
    "@fontsource-variable/roboto-slab": "^5.2.8",
    "@lit/context": "^1.1.6",
    "@lit/localize": "^0.12.2",
    "@material/web": "^2.4.1",
    "@materialx/material-color-utilities": "^0.4.8",
    "flag-icons": "^7.5.0",
    "lit": "^3.3.2"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.3",
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@custom-elements-manifest/to-markdown": "^0.0.13",
    "@lit/localize-tools": "^0.8.1",
    "@polyfea/core": "^1.3.0",
    "@storybook/addon-a11y": "^10.1.11",
    "@storybook/addon-docs": "^10.1.11",
    "@storybook/addon-vitest": "^10.1.11",
    "@storybook/web-components-vite": "^10.1.11",
    "@vitest/browser-playwright": "^4.0.16",
    "@vitest/coverage-istanbul": "^4.0.16",
    "@vitest/coverage-v8": "^4.0.16",
    "playwright": "^1.57.0",
    "precompress": "^13.0.3",
    "shadow-dom-testing-library": "^1.13.1",
    "storybook": "^10.1.11",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-static-copy": "^3.1.4",
    "vitest": "^4.0.16"
  },
  "customElements": "custom-elements.json"
}
